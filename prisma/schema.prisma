generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Teacher {
  id          Int          @id @default(autoincrement())
  name        String
  meetingLink String       @default("")
  assignments Assignment[]
}

model Class {
  id          Int          @id @default(autoincrement())
  name        String
  number      Int          @unique
  whatsappJid String?
  assignments Assignment[]
}

model WhatsappSession {
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("whatsapp_sessions")
}

model Sticker {
  id            Int            @id @default(autoincrement())
  base64        String
  mimetype      String         @default("image/webp")
  approved      Boolean        @default(false)
  label         String         @default("")
  createdAt     DateTime       @default(now())
  reminderRules ReminderRule[]
  @@map("stickers")
}

model ReminderRule {
  id            Int            @id @default(autoincrement())
  minutesBefore Int
  label         String
  stickerId     Int
  sticker       Sticker        @relation(fields: [stickerId], references: [id], onDelete: Cascade)
  enabled       Boolean        @default(true)
  reminderLogs  ReminderLog[]
  @@map("reminder_rules")
}

model ReminderLog {
  id           Int        @id @default(autoincrement())
  assignmentId Int
  ruleId       Int
  groupJid     String
  sentAt       DateTime   @default(now())
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  rule         ReminderRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  @@unique([assignmentId, ruleId])
  @@map("reminder_logs")
}

model TimeSlot {
  id          Int          @id @default(autoincrement())
  label       String
  startTime   String
  endTime     String
  orderIndex  Int          @default(0)
  isActive    Boolean      @default(true)
  assignments Assignment[]
}

model Assignment {
  id         Int      @id @default(autoincrement())
  date       String
  teacherId  Int
  classId    Int
  timeSlotId Int
  teacher    Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  class      Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  timeSlot   TimeSlot @relation(fields: [timeSlotId], references: [id], onDelete: Cascade)

  reminderLogs ReminderLog[]

  @@unique([date, classId, timeSlotId])
  @@index([teacherId, date])
}
